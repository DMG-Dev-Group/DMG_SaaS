# Credenciais da aplicação criada em dashboard.pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# itemId da conexão PicPay, vinculado no dashboard.pluggy.ai (ver PICPAY-SETUP.md)
PLUGGY_PICPAY_ITEM_ID=

# Caminho do JSON da service account do Firebase (gerado no console, NUNCA versionado)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# A cada quantos minutos o serviço consulta o PicPay em busca de transações novas
SYNC_INTERVAL_MINUTES=15
